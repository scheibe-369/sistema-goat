# Supabase - Frontend
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=SEU_ANON_KEY_AQUI

# Supabase - Edge Functions (configure no painel do Supabase: Project > Settings > Edge Functions > Secrets)
# WEBHOOK_SEND_MESSAGE_URL=https://SEU_DOMINIO/webhook/crm_goat_envia
# WEBHOOK_CLIENT_URL=https://SEU_DOMINIO/webhook/recebedadosclientenovo
